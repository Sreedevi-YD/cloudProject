.gradle/
build/
# Anchored to root: IntelliJ's default output folder is <project-root>/out/. An unanchored
# "out/" here previously matched com/enterprise/onboarding/application/port/out/ too, silently
# excluding that entire package from every commit since the first one.
/out/
*.class
.idea/
*.iml
.vscode/
HELP.md
.DS_Store
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
.env
*.log

# local profile runtime artifacts (H2 db file, uploaded documents) — not anchored to root,
# since running bootRun from a submodule resolves the relative path under that submodule.
data/
*.mv.db
*.trace.db
*.lock.db
